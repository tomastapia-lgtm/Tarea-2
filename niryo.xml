<mujoco model="niryo_ned2">
    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 0"/>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="512" height="512"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
        
        <mesh name="mesh_base" file="stl/1base.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_shoulder" file="stl/2shoulder.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_arm" file="stl/3arm.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_elbow" file="stl/4elbow.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_forearm" file="stl/5forearm.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_wrist" file="stl/6wrist.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_hand" file="stl/7arm.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_gripper_body" file="stl/12grippier.stl" scale="0.001 0.001 0.001"/>
        
        <mesh name="mesh_gripper_izq" file="stl/izquierdagripper.stl" scale="0.001 0.001 0.001"/>
        <mesh name="mesh_gripper_der" file="stl/derechagripper.stl" scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 .05" type="plane" material="grid"/>

        <body name="base_link" pos="0 0 0.065">
            <geom name="base_geom" type="mesh" mesh="mesh_base" pos="0 0 0" rgba="0.1 0.5 0.8 1"/>
            
            <body name="shoulder_link" pos="0.0055 -0.0025 0.08">
                <joint name="joint_1" type="hinge" axis="0 0 1" range="-2.949 2.949"/>
                <geom type="mesh" mesh="mesh_shoulder" pos="0 0 0" rgba="0.2 0.2 0.2 1"/>
                
                <body name="arm_link" pos="0 0.005 0.02">
                    <joint name="joint_2" type="hinge" axis="0 -1 0" range="-1.83 0.61"/>
                    <geom type="mesh" mesh="mesh_arm" pos="0 0 0" rgba="0.1 0.5 0.8 1"/>
                    
                    <body name="elbow_link" pos="0.02 0 0.225">
                        <joint name="joint_3" type="hinge" axis="0 -1 0" range="-2.68 3.14"/>
                        <geom type="mesh" mesh="mesh_elbow" pos="0 0 0" rgba="0.1 0.5 0.8 1"/>
                        
                        <body name="forearm_link" pos="0.0475 0 0.03">
                            <joint name="joint_4" type="hinge" axis="1 0 0" pos="0 0 0" range="-2.089 2.089"/>
                            <geom type="mesh" mesh="mesh_forearm" pos="0 0 0" rgba="0.2 0.2 0.2 1"/>
                            
                            <body name="wrist_link" pos="0.209 0 -0.0065">
                                <joint name="joint_5" type="hinge" axis="0 1 0" pos="0 0 0" range="-1.919 1.922"/>
                                <geom type="mesh" mesh="mesh_wrist" pos="0 0 0" rgba="0.1 0.5 0.8 1"/>
                                
                                <body name="wrist_flex_link" pos="0.03 -0.002 0.0075">
                                    <joint name="joint_6" type="hinge" axis="1 0 0" pos="0 0 0" range="-2.53 2.53"/>
                                    <geom type="mesh" mesh="mesh_hand" pos="0 0 0" rgba="0.2 0.2 0.2 1"/>
                                    
                                    <body name="tool_link" pos="0.0455 0.001 0.0025">
                                        <geom type="mesh" mesh="mesh_gripper_body" pos="0 0 0" rgba="0.1 0.1 0.1 1"/>
                                        
                                        <body name="left_finger" pos="0 0 0">
                                            <joint name="joint_base_to_left_finger" type="slide" axis="0 -1 0" range="0 0.02"/>
                                            <geom type="mesh" mesh="mesh_gripper_izq" pos="0 0 0" rgba="0.1 0.1 0.1 1"/>
                                        </body>

                                        <body name="right_finger" pos="0  0 0">
                                            <joint name="joint_base_to_right_finger" type="slide" axis="0 1 0" range="0 0.02"/>
                                            <geom type="mesh" mesh="mesh_gripper_der" pos="0 0 0" rgba="0.1 0.1 0.1 1"/>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
</mujoco>